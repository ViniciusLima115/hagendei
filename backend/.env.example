# Ambiente. Use production apenas com todos os itens obrigatorios preenchidos.
APP_ENV=development
INIT_DB_CREATE_ALL=true
BUSINESS_TIMEZONE=America/Sao_Paulo

# PostgreSQL / Neon
DATABASE_URL=

# Sessao e JWT. Gere valores independentes com um gerenciador de segredos.
JWT_SECRET=
JWT_ISSUER=hagendei-api
JWT_AUDIENCE=hagendei-web
JWT_EXPIRES_MINUTES=480
ADMIN_REAUTH_MAX_AGE_SECONDS=900
SESSION_COOKIE_NAME=hagendei_session
SESSION_COOKIE_SECURE=false
AUTH_EXPOSE_BEARER_TOKEN=false

# Admin global. Em producao, configure somente o hash bcrypt.
# Gere localmente com: python -c "from app.security import hash_senha; print(hash_senha('SUA-SENHA'))"
ADMIN_USUARIO=
ADMIN_SENHA_HASH=
# Compatibilidade apenas para desenvolvimento/testes antigos. Nao use em producao.
ADMIN_SENHA=

# AES-256-GCM para credenciais de pagamento.
# ENCRYPTION_KEY aceita 32 bytes em base64-url, hexadecimal ou texto.
# Gere base64-url: python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY_ID=primary
ENCRYPTION_KEY=
# Chaves antigas para rotacao, como objeto JSON: {"old-2026":"<chave>"}
ENCRYPTION_KEYRING=
# Pepper independente, com no minimo 32 bytes em producao.
PAYMENT_CREDENTIALS_PEPPER=

# Rede e proxy
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
TRUSTED_PROXY_IPS=127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_PRIVATE_NETWORKS=true

# URLs. Em producao, as URLs publicas devem usar HTTPS.
FRONTEND_URL=http://127.0.0.1:3000
BACKEND_URL=http://127.0.0.1:8000
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000
BOOKING_PUBLIC_BASE_URL=http://127.0.0.1:3000

# Mercado Pago. Credenciais de cada estabelecimento sao salvas pelo painel.
MERCADOPAGO_API_BASE=https://api.mercadopago.com
MERCADOPAGO_AUTH_BASE=https://auth.mercadopago.com.br
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_REDIRECT_URI=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_TIMEOUT_SECONDS=15
MERCADOPAGO_WEBHOOK_MAX_AGE_SECONDS=300
MERCADOPAGO_DEFAULT_ENVIRONMENT=production
# Taxa fixa opcional da plataforma por pagamento, em BRL. Vazio desabilita.
MERCADOPAGO_MARKETPLACE_FEE=

# Endpoints internos e limites
INTERNAL_REMINDER_TOKEN=
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_PUBLIC=30/minute
RATE_LIMIT_PAYMENT_STATUS=20/minute
RATE_LIMIT_WEBHOOK=120/minute
RATE_LIMIT_STORAGE_URI=memory://

# WhatsApp Cloud API / Meta
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ALLOW_UNSIGNED_WEBHOOKS=false

# MegaAPI (opcional)
MEGAAPI_WEBHOOK_TOKEN=
MEGAAPI_WEBHOOK_SECRET=
MEGAAPI_WEBHOOK_ALLOW_UNSIGNED=false
MEGAAPI_WEBHOOK_MAX_SKEW_SECONDS=300
MEGAAPI_SEND_URL=
MEGAAPI_ALLOWED_HOSTS=
MEGAAPI_SEND_TIMEOUT_SECONDS=8

# Email (configure SMTP ou Resend; nao use credenciais reais neste arquivo)
EMAIL_PROVIDER=auto
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=Hagendei
EMAIL_ACTION_BASE_URL=http://127.0.0.1:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
EMAIL_HTTP_TIMEOUT_SECONDS=10

# Swagger/OpenAPI. Desabilitado por padrao; se habilitado, use senha forte.
DOCS_ENABLED=false
DOCS_USER=
DOCS_PASS=

# Agenda
HORARIO_ABERTURA=8
HORARIO_FECHAMENTO=19
INTERVALO_MINUTOS=30
