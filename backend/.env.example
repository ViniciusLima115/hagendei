# Mercado Pago. Credenciais de cada estabelecimento sao salvas pelo painel.
=======
# Horarios padrao
# Hora de abertura usada como fallback quando o estabelecimento nao define funcionamento.
HORARIO_ABERTURA=8

# Hora de fechamento usada como fallback quando o estabelecimento nao define funcionamento.
HORARIO_FECHAMENTO=19

# Intervalo padrao da grade de horarios, em minutos.
INTERVALO_MINUTOS=30

# CORS
# Origens autorizadas a chamar a API pelo navegador, separadas por virgula.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Regex opcional para liberar origens dinamicas.
CORS_ALLOWED_ORIGIN_REGEX=

# Em development permite IPs privados/localhost; em production use false salvo necessidade explicita.
CORS_ALLOW_PRIVATE_NETWORKS=true

# URLs publicas
# URL do frontend usada em redirects OAuth e links publicos.
FRONTEND_URL=http://localhost:3000

# URL publica do backend usada em notification_url de webhooks. Em production deve ser HTTPS.
BACKEND_URL=http://127.0.0.1:8000

# Alias legado de BACKEND_URL. Mantenha vazio se usar BACKEND_URL.
BACKEND_PUBLIC_BASE_URL=

# URL base publica usada para montar links de agendamento.
BOOKING_PUBLIC_BASE_URL=http://localhost:3000

# Mercado Pago - OAuth por estabelecimento
# Tokens e credenciais sensiveis ficam criptografados em payment_accounts.
# Obrigatoria em production. Client ID da aplicacao OAuth cadastrada no Mercado Pago.
MERCADOPAGO_CLIENT_ID=

# Obrigatoria em production. Client Secret da aplicacao OAuth cadastrada no Mercado Pago.
MERCADOPAGO_CLIENT_SECRET=

# Obrigatoria em production. Callback OAuth cadastrado no Mercado Pago.
MERCADOPAGO_REDIRECT_URI=http://127.0.0.1:8000/payments/mercadopago/callback

# Obrigatoria em production. Secret usado para validar x-signature dos webhooks Mercado Pago.
# Nao existe fallback por token em query string.
MERCADOPAGO_WEBHOOK_SECRET=

# Timeout das chamadas HTTP para Mercado Pago, em segundos.
MERCADOPAGO_TIMEOUT_SECONDS=15

# Opcional (sandbox/proxy)
# Base da API Mercado Pago; altere apenas para sandbox/proxy controlado.
