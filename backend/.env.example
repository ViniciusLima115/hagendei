# Ambiente da aplicacao: use development, staging ou production.
APP_ENV=development

# Em development cria/ajusta tabelas automaticamente; em production prefira migrations.
INIT_DB_CREATE_ALL=true

# Banco de dados
# URL completa do banco. Pode ser Postgres local, Neon/Postgres gerenciado ou SQLite em dev.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/barbearia

# Autenticacao JWT
# Segredo usado para assinar tokens da aplicacao. Troque em qualquer ambiente real.
JWT_SECRET=troque-esta-chave-em-producao

# Tempo de expiracao dos tokens JWT da aplicacao, em minutos.
JWT_EXPIRES_MINUTES=480

# Compatibilidade (opcional): alguns ambientes ainda usam SECRET_KEY
# Alias legado de JWT_SECRET para ambientes antigos.
SECRET_KEY=troque-esta-chave-em-producao

# Criptografia de tokens sensiveis (Mercado Pago)
# Obrigatoria em production. Deve ser uma chave Fernet ou 32 bytes.
# Gere localmente com:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Horarios padrao
# Hora de abertura usada como fallback quando o estabelecimento nao define funcionamento.
HORARIO_ABERTURA=8

# Hora de fechamento usada como fallback quando o estabelecimento nao define funcionamento.
HORARIO_FECHAMENTO=19

# Intervalo padrao da grade de horarios, em minutos.
INTERVALO_MINUTOS=30

# CORS
# Origens autorizadas a chamar a API pelo navegador, separadas por virgula.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Regex opcional para liberar origens dinamicas.
CORS_ALLOWED_ORIGIN_REGEX=

# Em development permite IPs privados/localhost; em production use false salvo necessidade explicita.
CORS_ALLOW_PRIVATE_NETWORKS=true

# URLs publicas
# URL do frontend usada em redirects OAuth e links publicos.
FRONTEND_URL=http://localhost:3000

# URL publica do backend usada em notification_url de webhooks. Em production deve ser HTTPS.
BACKEND_URL=http://127.0.0.1:8000

# Alias legado de BACKEND_URL. Mantenha vazio se usar BACKEND_URL.
BACKEND_PUBLIC_BASE_URL=

# URL base publica usada para montar links de agendamento.
BOOKING_PUBLIC_BASE_URL=http://localhost:3000

# Mercado Pago - OAuth por estabelecimento
# Tokens e credenciais sensiveis ficam criptografados em payment_accounts.
# Obrigatoria em production. Client ID da aplicacao OAuth cadastrada no Mercado Pago.
MERCADOPAGO_CLIENT_ID=

# Obrigatoria em production. Client Secret da aplicacao OAuth cadastrada no Mercado Pago.
MERCADOPAGO_CLIENT_SECRET=

# Obrigatoria em production. Callback OAuth cadastrado no Mercado Pago.
MERCADOPAGO_REDIRECT_URI=http://127.0.0.1:8000/payments/mercadopago/callback

# Obrigatoria em production. Secret usado para validar x-signature dos webhooks Mercado Pago.
# Nao existe fallback por token em query string.
MERCADOPAGO_WEBHOOK_SECRET=

# Timeout das chamadas HTTP para Mercado Pago, em segundos.
MERCADOPAGO_TIMEOUT_SECONDS=15

# Opcional (sandbox/proxy)
# Base da API Mercado Pago; altere apenas para sandbox/proxy controlado.
MERCADOPAGO_API_BASE=https://api.mercadopago.com

# Base OAuth Mercado Pago.
MERCADOPAGO_AUTH_BASE=https://auth.mercadopago.com.br

# PicPay - checkout por estabelecimento
# Credenciais individuais PicPay NAO devem ficar no .env.
# O ADM cadastra por estabelecimento e o backend salva criptografado em payment_accounts:
# - access_token: x-picpay-token
# - refresh_token: x-seller-token usado para validar callback/webhook
# Base da API PicPay E-commerce/public checkout. Altere apenas para sandbox/proxy controlado.
PICPAY_API_BASE=https://appws.picpay.com/ecommerce/public

# Timeout das chamadas HTTP para PicPay, em segundos.
PICPAY_TIMEOUT_SECONDS=15

# Tempo padrao de bloqueio temporario do horario aguardando pagamento, entre 5 e 60 minutos.
PAYMENT_DEFAULT_HOLD_MINUTES=10

# Scheduler / jobs internos
# Token para proteger rotas internas de jobs. Recomendado em production.
INTERNAL_REMINDER_TOKEN=

# Email
# Remetente padrao dos emails transacionais.
EMAIL_FROM=noreply@seudominio.com

# Nome exibido do remetente.
EMAIL_FROM_NAME=Nome do Sistema

# Servidor SMTP.
SMTP_HOST=smtp.seudominio.com

# Porta SMTP.
SMTP_PORT=587

# Usuario SMTP. Deixe vazio se o provedor nao exigir autenticacao.
SMTP_USER=

# Senha SMTP. Nunca versionar valor real.
SMTP_PASSWORD=

# Docs protegidos por Basic Auth
# Usuario para acessar /docs.
DOCS_USER=admin

# Senha para acessar /docs. Troque em ambientes reais.
DOCS_PASS=

# Webhook WhatsApp/MegaAPI (opcional)
# Token de integracao WhatsApp, se usado.
WHATSAPP_TOKEN=

# Identificador do numero WhatsApp, se usado.
PHONE_NUMBER_ID=

# Token legado para webhook MegaAPI, se usado.
MEGAAPI_WEBHOOK_TOKEN=

# Secret HMAC para validar webhook MegaAPI, se usado.
MEGAAPI_WEBHOOK_SECRET=

# Permite webhook MegaAPI sem assinatura. Use false em production.
MEGAAPI_WEBHOOK_ALLOW_UNSIGNED=false

# Janela maxima de validade de assinatura MegaAPI, em segundos.
MEGAAPI_WEBHOOK_MAX_SKEW_SECONDS=300

# URL de envio MegaAPI, se usado.
MEGAAPI_SEND_URL=
